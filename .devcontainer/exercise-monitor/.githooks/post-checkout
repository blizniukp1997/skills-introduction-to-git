#!/bin/bash

LOG_FILE="/workspaces/exercise-monitor.log"

echo "Git Hook: Post Checkout"

if [ -z "${GITHUB_TOKEN}" ] || [ -z "${GITHUB_REPOSITORY}" ]; then
  echo "Exercise Monitor: Error: GITHUB_TOKEN or GITHUB_REPOSITORY is not set, skipping post-checkout hook" >> "$LOG_FILE"
  exit 0
fi

# Get checkout information
PREVIOUS_HEAD=$1
NEW_HEAD=$2
BRANCH_NAME=$(git branch --show-current)
REPO_NAME=$(basename "$(git rev-parse --show-toplevel)")

# Send repository dispatch event
HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" -X POST \
  -H "Accept: application/vnd.github.v3+json" \
  -H "Authorization: token ${GITHUB_TOKEN}" \
  "https://api.github.com/repos/${GITHUB_REPOSITORY}/dispatches" \
  -d '{
    "event_type": "post-checkout",
    "client_payload": {
      "previous_head": "'"$PREVIOUS_HEAD"'",
      "new_head": "'"$NEW_HEAD"'",
      "branch_name": "'"$BRANCH_NAME"'",
      "repository_name": "'"$REPO_NAME"'",
      "timestamp": "'"$(date -u +"%Y-%m-%dT%H:%M:%SZ")"'"
    }
  }' 2>>"$LOG_FILE")

if [ $? -ne 0 ]; then
  echo "Exercise Monitor: Error: curl failed for post-checkout dispatch" >> "$LOG_FILE"
elif [ "$HTTP_STATUS" -ge 400 ] 2>/dev/null; then
  echo "Exercise Monitor: Error: post-checkout dispatch returned HTTP $HTTP_STATUS" >> "$LOG_FILE"
fi